rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for role-based access
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['president', 'vice-president', 'community-manager'];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /invites/{inviteId} {
      // Allow anyone with the link to read it (for registration), but only admins can create/manage
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /activityFeed/{feedId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // Allows members to RSVP
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Members can upload for approval
      allow update, delete: if isAdmin(); // Admins handle approval/rejection
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if true;
      allow create: if true; // Anyone (even public) can submit inquiries
      allow update, delete: if isAdmin();
    }

    match /faq/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
